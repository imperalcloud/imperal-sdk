{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://imperal.io/schemas/ui_children/select.json",
  "title": "Select options",
  "description": "Array of option dicts for ui.Select and ui.MultiSelect. Each option: {value, label}.",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["value", "label"],
    "properties": {
      "value": {"type": "string"},
      "label": {"type": "string"}
    },
    "additionalProperties": true
  }
}
