{
  "additionalProperties": false,
  "description": "Canonical shape of Event payloads published on Redis streams and consumed by the automation engine, SSE delivery, and Panel live-refresh. Replaces the textual RPC-I1..I10 invariants with a machine-checkable contract.",
  "properties": {
    "event_type": {
      "title": "Event Type",
      "type": "string"
    },
    "timestamp": {
      "default": "",
      "title": "Timestamp",
      "type": "string"
    },
    "user_id": {
      "default": "",
      "title": "User Id",
      "type": "string"
    },
    "tenant_id": {
      "default": "",
      "title": "Tenant Id",
      "type": "string"
    },
    "data": {
      "additionalProperties": true,
      "title": "Data",
      "type": "object"
    },
    "event_id": {
      "type": "string",
      "description": "EV6 UUIDv7 idempotency/dedup key"
    },
    "schema_version": {
      "type": "integer",
      "minimum": 1,
      "description": "EV7 monotone breaking-change marker"
    },
    "source": {
      "type": "string",
      "enum": [
        "user",
        "system",
        "automation",
        "rbac",
        "mcp",
        "webhook"
      ],
      "description": "EV8 AuditSource value"
    }
  },
  "required": [
    "event_type"
  ],
  "title": "Imperal Platform Event Envelope",
  "type": "object",
  "$id": "https://imperal.io/schemas/event.schema.json"
}
