{
  "$defs": {
    "IRApp": {
      "additionalProperties": false,
      "description": "The app body of an IR envelope (everything an app declares).",
      "properties": {
        "id": {
          "minLength": 1,
          "title": "Id",
          "type": "string"
        },
        "version": {
          "title": "Version",
          "type": "string"
        },
        "title": {
          "title": "Title",
          "type": "string"
        },
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        },
        "icon": {
          "default": "",
          "title": "Icon",
          "type": "string"
        },
        "capabilities": {
          "items": {
            "type": "string"
          },
          "title": "Capabilities",
          "type": "array"
        },
        "data": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Data"
        },
        "functions": {
          "items": {
            "$ref": "#/$defs/IRFunction"
          },
          "title": "Functions",
          "type": "array"
        },
        "ui": {
          "anyOf": [
            {
              "$ref": "#/$defs/IRUi"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "skeleton": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/IRSkeleton"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Skeleton"
        },
        "automations": {
          "items": {
            "additionalProperties": true,
            "type": "object"
          },
          "title": "Automations",
          "type": "array"
        },
        "events": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Events"
        },
        "lifecycle": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lifecycle"
        }
      },
      "required": [
        "id",
        "version",
        "title"
      ],
      "title": "IRApp",
      "type": "object"
    },
    "IRFunction": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        },
        "params_schema": {
          "additionalProperties": true,
          "title": "Params Schema",
          "type": "object"
        },
        "return_schema": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Return Schema"
        },
        "action_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Action Type"
        },
        "effects": {
          "items": {
            "type": "string"
          },
          "title": "Effects",
          "type": "array"
        },
        "event": {
          "default": "",
          "title": "Event",
          "type": "string"
        },
        "impl": {
          "discriminator": {
            "mapping": {
              "code": "#/$defs/ImplCode",
              "declarative": "#/$defs/ImplDeclarative"
            },
            "propertyName": "kind"
          },
          "oneOf": [
            {
              "$ref": "#/$defs/ImplCode"
            },
            {
              "$ref": "#/$defs/ImplDeclarative"
            }
          ],
          "title": "Impl"
        }
      },
      "required": [
        "name",
        "impl"
      ],
      "title": "IRFunction",
      "type": "object"
    },
    "IRPanel": {
      "additionalProperties": false,
      "description": "A single panel declared by an extension in the IR envelope.",
      "properties": {
        "panel_id": {
          "title": "Panel Id",
          "type": "string"
        },
        "slot": {
          "title": "Slot",
          "type": "string"
        },
        "title": {
          "default": "",
          "title": "Title",
          "type": "string"
        },
        "icon": {
          "default": "",
          "title": "Icon",
          "type": "string"
        },
        "render": {
          "discriminator": {
            "mapping": {
              "code": "#/$defs/RenderCode",
              "static": "#/$defs/RenderStatic",
              "template": "#/$defs/RenderTemplate"
            },
            "propertyName": "kind"
          },
          "oneOf": [
            {
              "$ref": "#/$defs/RenderStatic"
            },
            {
              "$ref": "#/$defs/RenderTemplate"
            },
            {
              "$ref": "#/$defs/RenderCode"
            }
          ],
          "title": "Render"
        }
      },
      "required": [
        "panel_id",
        "slot",
        "render"
      ],
      "title": "IRPanel",
      "type": "object"
    },
    "IRSkeleton": {
      "additionalProperties": false,
      "description": "One skeleton section declared by an extension.\n\n``producer`` follows the same :class:`~imperal_sdk.ir.schema.Impl`\ndiscriminated union used by :class:`~imperal_sdk.ir.schema.IRFunction`.\nFor skeleton refresh tools the kind is always ``\"code\"``.",
      "properties": {
        "section": {
          "title": "Section",
          "type": "string"
        },
        "shape": {
          "additionalProperties": true,
          "title": "Shape",
          "type": "object"
        },
        "producer": {
          "discriminator": {
            "mapping": {
              "code": "#/$defs/ImplCode",
              "declarative": "#/$defs/ImplDeclarative"
            },
            "propertyName": "kind"
          },
          "oneOf": [
            {
              "$ref": "#/$defs/ImplCode"
            },
            {
              "$ref": "#/$defs/ImplDeclarative"
            }
          ],
          "title": "Producer"
        },
        "alert": {
          "default": false,
          "title": "Alert",
          "type": "boolean"
        },
        "ttl": {
          "default": 300,
          "title": "Ttl",
          "type": "integer"
        }
      },
      "required": [
        "section",
        "producer"
      ],
      "title": "IRSkeleton",
      "type": "object"
    },
    "IRUi": {
      "additionalProperties": false,
      "description": "UI section of an IR app \u2014 a list of declared panels.",
      "properties": {
        "panels": {
          "items": {
            "$ref": "#/$defs/IRPanel"
          },
          "title": "Panels",
          "type": "array"
        }
      },
      "title": "IRUi",
      "type": "object"
    },
    "ImplCode": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "code",
          "title": "Kind",
          "type": "string"
        },
        "module": {
          "title": "Module",
          "type": "string"
        },
        "entry": {
          "title": "Entry",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "module",
        "entry"
      ],
      "title": "ImplCode",
      "type": "object"
    },
    "ImplDeclarative": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "declarative",
          "title": "Kind",
          "type": "string"
        },
        "steps": {
          "items": {
            "additionalProperties": true,
            "type": "object"
          },
          "title": "Steps",
          "type": "array"
        }
      },
      "required": [
        "kind"
      ],
      "title": "ImplDeclarative",
      "type": "object"
    },
    "RenderCode": {
      "additionalProperties": false,
      "description": "Tier-3 render: a Python module + callable entry point (code panel).",
      "properties": {
        "kind": {
          "const": "code",
          "title": "Kind",
          "type": "string"
        },
        "module": {
          "title": "Module",
          "type": "string"
        },
        "entry": {
          "title": "Entry",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "module",
        "entry"
      ],
      "title": "RenderCode",
      "type": "object"
    },
    "RenderStatic": {
      "additionalProperties": false,
      "description": "Tier-1 render: a plain serialisable UI-node tree (no runtime needed).",
      "properties": {
        "kind": {
          "const": "static",
          "title": "Kind",
          "type": "string"
        },
        "tree": {
          "additionalProperties": true,
          "title": "Tree",
          "type": "object"
        }
      },
      "required": [
        "kind"
      ],
      "title": "RenderStatic",
      "type": "object"
    },
    "RenderTemplate": {
      "additionalProperties": false,
      "description": "Tier-2 render: a declarative template tree evaluated at render time.",
      "properties": {
        "kind": {
          "const": "template",
          "title": "Kind",
          "type": "string"
        },
        "tree": {
          "additionalProperties": true,
          "title": "Tree",
          "type": "object"
        }
      },
      "required": [
        "kind"
      ],
      "title": "RenderTemplate",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Versioned root of the Imperal IR.",
  "properties": {
    "ir_version": {
      "title": "Ir Version",
      "type": "string"
    },
    "sdl_vocab_version": {
      "default": "1",
      "title": "Sdl Vocab Version",
      "type": "string"
    },
    "contract_version": {
      "default": "1.0",
      "title": "Contract Version",
      "type": "string"
    },
    "app": {
      "$ref": "#/$defs/IRApp"
    }
  },
  "required": [
    "ir_version",
    "app"
  ],
  "title": "Imperal IR Envelope",
  "type": "object",
  "$id": "https://imperal.io/schemas/ir.schema.json"
}
