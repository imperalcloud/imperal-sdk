{
  "$defs": {
    "FunctionCallModel": {
      "additionalProperties": false,
      "description": "Pydantic contract for `FunctionCall.to_dict()` output.\n\nRecords a single `@chat.function` invocation inside `ChatResult`.\nCrosses Temporal activity boundaries \u2014 every field travels the wire.",
      "properties": {
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "params": {
          "additionalProperties": true,
          "title": "Params",
          "type": "object"
        },
        "action_type": {
          "enum": [
            "read",
            "write",
            "destructive"
          ],
          "title": "Action Type",
          "type": "string"
        },
        "success": {
          "title": "Success",
          "type": "boolean"
        },
        "result": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Result"
        },
        "intercepted": {
          "default": false,
          "title": "Intercepted",
          "type": "boolean"
        },
        "event": {
          "default": "",
          "title": "Event",
          "type": "string"
        }
      },
      "required": [
        "name",
        "action_type",
        "success"
      ],
      "title": "FunctionCallModel",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Serialized return from ChatExtension._handle() \u2014 the kernel-transport form of a chat turn's output. Underscore-prefixed keys distinguish transport metadata from raw tool response. Crosses Temporal activity history.",
  "properties": {
    "response": {
      "default": "",
      "title": "Response",
      "type": "string"
    },
    "_handled": {
      "default": false,
      "title": "Handled",
      "type": "boolean"
    },
    "_functions_called": {
      "items": {
        "$ref": "#/$defs/FunctionCallModel"
      },
      "title": "Functions Called",
      "type": "array"
    },
    "_had_successful_action": {
      "default": false,
      "title": "Had Successful Action",
      "type": "boolean"
    },
    "_message_type": {
      "default": "text",
      "title": "Message Type",
      "type": "string"
    },
    "_action_meta": {
      "additionalProperties": true,
      "title": "Action Meta",
      "type": "object"
    },
    "_intercepted": {
      "default": false,
      "title": "Intercepted",
      "type": "boolean"
    },
    "_task_cancelled": {
      "default": false,
      "title": "Task Cancelled",
      "type": "boolean"
    },
    "_narration_emission": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Narration Emission"
    }
  },
  "title": "Imperal ChatResult Payload",
  "type": "object",
  "$id": "https://imperal.io/schemas/chat_result.schema.json"
}